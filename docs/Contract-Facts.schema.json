{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/boilermolt/otrak/docs/Contract-Facts.schema.json",
  "title": "OTRAK Contract Facts",
  "type": "object",
  "required": [
    "fact_id",
    "agreement_id",
    "union",
    "topic",
    "conditions",
    "value",
    "citation",
    "confidence",
    "status",
    "extracted_at"
  ],
  "properties": {
    "fact_id": { "type": "string" },
    "agreement_id": { "type": "string" },
    "union": { "type": "string" },
    "topic": {
      "type": "string",
      "enum": [
        "overtime_rate_multiplier",
        "weekly_overtime_threshold",
        "daily_overtime_threshold"
      ]
    },
    "conditions": { "type": "object" },
    "value": {},
    "unit": { "type": ["string", "null"] },
    "citation": {
      "type": "object",
      "required": ["source", "file", "page", "chunk_id", "quote"],
      "properties": {
        "source": { "type": "string" },
        "file": { "type": "string" },
        "page": { "type": "integer" },
        "chunk_id": { "type": "string" },
        "quote": { "type": "string" }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "type": "string", "enum": ["proposed", "approved", "rejected"] },
    "extracted_at": { "type": "string" }
  }
}
